# ── Local development ────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
CLIENT_URL=http://localhost:5173
JWT_SECRET=change-this-to-a-random-secret-in-production
DATABASE_PATH=./data/fbuploadpro.db

# ── Railway production (set in Railway → Variables on Web + Worker) ─────
# NODE_ENV=production
# PORT=3001
# CLIENT_URL=https://YOUR-APP.up.railway.app
# APP_BASE_DOMAIN=fbuploadplus.com
# JWT_SECRET=use-a-long-random-string-min-32-chars
# DATABASE_PATH=/app/data/fbuploadpro.db
# Public self-signup. On by default; set false to close.
# PUBLIC_SIGNUP_ENABLED=false
# New users join this agency as admin (owner credits tokens manually). Optional overrides:
# PUBLIC_SIGNUP_AGENCY_SUBDOMAIN=your-agency-subdomain
# PUBLIC_SIGNUP_AGENCY_ID=
# If unset, uses the primary agency owned by PLATFORM_ADMIN_EMAILS.
# PUBLIC_SIGNUP_OWNER_EMAIL=fbuploadplus@gmail.com
# PUBLIC_SIGNUP_BONUS_TOKENS=0
# FACEBOOK_REDIRECT_URI=https://YOUR-APP.up.railway.app/facebook/callback

# Facebook OAuth — set here OR per-agency in Settings → Facebook BYOC
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:5173/facebook/callback
# Production / Railway:
# FACEBOOK_REDIRECT_URI=https://your-app.up.railway.app/facebook/callback

# Video automation (included in Dockerfile; install on VPS PATH for DigitalOcean)
# yt-dlp + ffmpeg

# Worker process (run separately: npm run worker)
WORKER_CONCURRENCY=20
WORKER_POLL_MS=1000
JOB_LOG_RETAIN_DAYS=7

# Posting schedule timezone (USA Eastern for peak engagement)
SCHEDULE_TIMEZONE=America/New_York

# ── Download proxy pool (residential static — rotate per reel) ───────────
# Add 50+ proxies for heavy Instagram/TikTok/YouTube downloading at scale.
# Set on BOTH Web + Worker services on Railway.
#
# Option A: comma or newline separated proxy URLs
# DOWNLOAD_PROXY_POOL=http://user:pass@1.2.3.4:8080,http://user:pass@5.6.7.8:8080
#
# Option B: one proxy per line in a file (good for 50+ IPs)
# PROXY_POOL_FILE=/app/data/proxy-pool.txt
# Or upload via Settings → Download Proxies (owner) — saves to data/proxy-pool.txt automatically
#
# Option C: legacy single Webshare proxy (auto-added to pool)
# DOWNLOAD_PROXY_URL=http://YOUR_USER:YOUR_PASS@p.webshare.io:80
#
# PROXY_DIRECT_FIRST=true          # try server IP first, then pool (default)
# PROXY_DIRECT_FIRST=false         # always use proxies (fbuploadpro-style at scale)
# PROXY_MAX_ATTEMPTS_PER_JOB=50    # max proxies to try per video download
# PROXY_COOLDOWN_MS=300000         # 5 min cooldown after repeated failures
# PROXY_MAX_FAILURES_BEFORE_COOLDOWN=2
# PROXY_POOL_ENABLED=false         # disable pool entirely

# ── Cloudflare R2 buffer (Pro-style CDN previews) ───────────────────────
# When set, pre-downloaded reels upload to R2 and play via signed URLs (survives redeploys).
# Create bucket + API token in Cloudflare dashboard → R2 → Manage R2 API Tokens.
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=fbuploadpro-adu-buffer
# R2_PREFIX=adu-buffer
# R2_SIGNED_URL_TTL_SEC=3600

# ── Pre-download queue (Pro-style: download ahead, publish on schedule) ──
# PREFILL_ENABLED=true               # fill queue in background (default)
# PREFILL_MAX_QUEUE_PER_PAGE=50      # max pre-downloaded reels per page
# PREFILL_INITIAL_BURST=12           # upfront jobs queued when source is assigned
# PREFILL_CATALOG_PROBE_LIMIT=100    # max reels counted in creator catalog probe
# PREFILL_DISCOVERY_LIST_LIMIT=50    # reels scanned when picking next download
# PREFILL_CRON=*/3 * * * *           # refill queue every 3 minutes
# ── Local dev login (optional — creates verified owner on `npm run seed:dev`) ──
# PLATFORM_ADMIN_SEED_EMAIL=dev@gmail.com
# PLATFORM_ADMIN_SEED_PASSWORD=dev123456

# Legacy Webshare fields (still supported — merged into pool)
# WEBSHARE_PROXY_HOST=p.webshare.io
# WEBSHARE_PROXY_PORT=80
# WEBSHARE_PROXY_USERNAME=
# WEBSHARE_PROXY_PASSWORD=
# WEBSHARE_PROXY_ENABLED=false

# ── News feed AI (Gemini recommended — free tier at aistudio.google.com) ──
# Set here OR per-agency under News Feed → AI headline settings
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-3.1-flash-lite
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# AI_PROVIDER=gemini

# WhatsApp for token purchases
WHATSAPP_NUMBER=923080752936

# SMTP for email verification (optional locally — codes logged to console when unset)
# Provider shortcut (optional): gmail | outlook | privateemail
# SMTP_PROVIDER=gmail
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=no-reply@yourdomain.com
# SMTP_SECURE=false
#
# Gmail quick setup:
# SMTP_PROVIDER=gmail
# SMTP_USER=yourgmail@gmail.com
# SMTP_PASS=your-16-char-app-password
# SMTP_FROM=yourgmail@gmail.com
#
# Outlook quick setup:
# SMTP_PROVIDER=outlook
# SMTP_USER=you@outlook.com
# SMTP_PASS=your-password-or-app-password
# SMTP_FROM=you@outlook.com
#
# Namecheap Private Email:
# SMTP_PROVIDER=privateemail
# SMTP_USER=no-reply@yourdomain.com
# SMTP_PASS=your-real-mailbox-password
# SMTP_FROM=no-reply@yourdomain.com
# SMTP_PORT=465
# SMTP_SECURE=true

# ── Platform Ops Console (Web + Worker) ────────────────────────────────
# Comma-separated Gmail addresses allowed to access /ops (recommended — lock to your email only)
# Example: you@gmail.com
PLATFORM_ADMIN_EMAILS=you@gmail.com
# Seed / sync platform admin on startup (set password in Railway only — never commit)
PLATFORM_ADMIN_SEED_EMAIL=admin@fbuploadplus.com
PLATFORM_ADMIN_SEED_PASSWORD=
# Optional alert recipients (comma-separated)
OPS_ALERT_EMAILS=
OPS_ALERT_INTERVAL_MS=900000
OPS_AUTO_RETRY_ENABLED=true
OPS_AUTO_RETRY_MAX=3
OPS_SELF_HEAL_PAGE_FAIL_MAX=5
OPS_SELF_HEAL_SOURCE_FAIL_MAX=8
