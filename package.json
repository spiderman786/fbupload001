{
  "name": "fbuploadpro-clone",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -n client,server,worker -c cyan,green,yellow \"npm run dev:client\" \"npm run dev:server\" \"npm run dev:worker\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "dev:worker": "tsx watch server/worker.ts",
    "start": "tsx server/index.ts",
    "start:production": "concurrently -k -n web,worker -c green,yellow \"tsx server/index.ts\" \"tsx server/worker.ts\"",
    "worker": "tsx server/worker.ts",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "seed:dev": "tsx scripts/seed-dev-login.ts",
    "db:migrate-to-postgres": "tsx scripts/migrate-sqlite-to-postgres.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/s3-request-presigner": "^3.1075.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "concurrently": "^10.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "deasync": "^0.1.31",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.21.0",
    "node-cron": "^4.4.1",
    "pg": "^8.16.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.18.0",
    "rss-parser": "^3.13.0",
    "sharp": "^0.35.2",
    "tsx": "^4.22.4",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/deasync": "^0.1.5",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.12.3",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.15.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
